<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_credit_commission_buttons" model="ir.ui.view">
        <field name="name">sale.order.credit.commission.buttons</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sd_credit_logs" type="object" class="oe_stat_button" icon="fa-shield"
                    groups="sales_team.group_sale_salesman">
                    <field name="sd_credit_log_count" widget="statinfo" string="Credit Logs"/>
                </button>
                <button name="action_view_sd_commission_logs" type="object" class="oe_stat_button" icon="fa-percent"
                    groups="sales_team.group_sale_salesman">
                    <field name="sd_commission_log_count" widget="statinfo" string="Commissions"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_sd_credit_approve" string="Approve Credit" type="object"
                    class="btn-primary"
                    groups="sales_team.group_sale_manager"
                    invisible="state != 'waiting_approval'"/>
                <button name="action_sd_credit_reject" string="Reject Order" type="object"
                    class="btn-secondary"
                    groups="sales_team.group_sale_manager"
                    invisible="state != 'waiting_approval'"
                    confirm="This will cancel the quotation. Proceed?"/>
            </xpath>
            <xpath expr="//notebook/page[last()]" position="after">
                <page string="Credit &amp; commission" name="Credit_commission" groups="sales_team.group_sale_salesman">
                    <group string="Credit &amp; commission" >
                        <field name="sd_exposure_amount"/>
                        <field name="sd_credit_limit_amount"/>
                        <field name="sd_credit_utilization_pct"/>
                        <field name="sd_needs_manager_approval"/>
                        <field name="sd_commission_preview"/>
                        <field name="sd_commission_rate_preview"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Statusbar visibility for waiting approval (included in generic status field rendering) -->
    <record id="sale_order_exposure_column" model="ir.ui.view">
        <field name="name">sale.order.list.exposure</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <field name="amount_total" position="after">
                <field name="sd_exposure_amount" optional="hide" string="Exposure"/>
            </field>
            <field name="state" position="attributes">
                <attribute name="decoration-warning">state == 'waiting_approval'</attribute>
            </field>
        </field>
    </record>
</odoo>
