<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_sd_credit_form" model="ir.ui.view">
        <field name="name">res.company.sd.credit.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="sd_credit_commission" string="Credit &amp; Commission">
                    <group string="Credit Approval">
                        <field name="sd_credit_approval_threshold"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
