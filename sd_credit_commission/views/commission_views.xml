<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sd_commission_log_list" model="ir.ui.view">
        <field name="name">sd.commission.log.list</field>
        <field name="model">sd.commission.log</field>
        <field name="arch" type="xml">
            <list string="Commission Logs">
                <field name="sale_order_id"/>
                <field name="user_id"/>
                <field name="untaxed_amount"/>
                <field name="commission_amount"/>
                <field name="commission_rate"/>
                <field name="confirmed_on"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sd_commission_log_form" model="ir.ui.view">
        <field name="name">sd.commission.log.form</field>
        <field name="model">sd.commission.log</field>
        <field name="arch" type="xml">
            <form string="Commission Log">
                <sheet>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="user_id"/>
                        <field name="confirmed_on"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="untaxed_amount"/>
                        <field name="commission_amount"/>
                        <field name="commission_rate"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sd_commission_logs" model="ir.actions.act_window">
        <field name="name">Commission Logs</field>
        <field name="res_model">sd.commission.log</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="context">{}</field>
    </record>
</odoo>
